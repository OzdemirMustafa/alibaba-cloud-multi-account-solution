                <mxCell id="chCatTgVxCdAMBvIMWZu-18" value="&lt;span id=&quot;docs-internal-guid-0d93352b-7fff-359b-9a5e-341d21ccfe57&quot; style=&quot;font-size: 10px;&quot;&gt;&lt;ul style=&quot;margin-top: 0px; margin-bottom: 0px;&quot;&gt;&lt;li dir=&quot;ltr&quot; style=&quot;list-style-type: disc; background-color: transparent; vertical-align: baseline;&quot;&gt;&lt;p dir=&quot;ltr&quot; style=&quot;line-height: 1.38; margin-top: 0pt; margin-bottom: 0pt;&quot;&gt;&lt;span style=&quot;background-color: transparent; vertical-align: baseline;&quot;&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;&lt;b style=&quot;&quot;&gt;Region&lt;/b&gt; :&amp;nbsp; Frankfurt (eu-central-1, PRIMARY), London (eu-west-1, DR)&lt;/font&gt;&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li dir=&quot;ltr&quot; style=&quot;list-style-type: disc; background-color: transparent; vertical-align: baseline;&quot;&gt;&lt;p dir=&quot;ltr&quot; style=&quot;line-height: 1.38; margin-top: 0pt; margin-bottom: 0pt;&quot;&gt;&lt;span style=&quot;background-color: transparent; vertical-align: baseline;&quot;&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;&lt;b&gt;Availability Zones :&lt;/b&gt; eu-west-1a &amp;amp; eu-west-1b, eu-west-2a &amp;amp; eu-west-2b&amp;nbsp;&lt;/font&gt;&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li dir=&quot;ltr&quot; style=&quot;list-style-type: disc; background-color: transparent; vertical-align: baseline;&quot;&gt;&lt;p dir=&quot;ltr&quot; style=&quot;line-height: 1.38; margin-top: 0pt; margin-bottom: 0pt;&quot;&gt;&lt;span style=&quot;background-color: transparent; vertical-align: baseline;&quot;&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;&lt;b&gt;VPC&lt;/b&gt;: Custom VPC with IPv4-enabled. CIDR X.X.0.0/1&lt;/font&gt;&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li dir=&quot;ltr&quot; style=&quot;list-style-type: disc; background-color: transparent; vertical-align: baseline;&quot;&gt;&lt;p dir=&quot;ltr&quot; style=&quot;line-height: 1.38; margin-top: 0pt; margin-bottom: 0pt;&quot;&gt;&lt;span style=&quot;background-color: transparent; vertical-align: baseline;&quot;&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;&lt;b&gt;VSwitches&lt;/b&gt;: Custom 5 VSwitches. 1 public (SLB) and 4 private (ACK, Database, Cache, and Queue).&amp;nbsp;&amp;nbsp;&lt;/font&gt;&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li dir=&quot;ltr&quot; style=&quot;list-style-type: disc; background-color: transparent; vertical-align: baseline;&quot;&gt;&lt;p dir=&quot;ltr&quot; style=&quot;line-height: 1.38; margin-top: 0pt; margin-bottom: 0pt;&quot;&gt;&lt;span style=&quot;background-color: transparent; vertical-align: baseline;&quot;&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;&lt;b&gt;Shared Services:&lt;/b&gt; Alibaba Cloud DNS, OSS, CloudMonitor, ActionTrail, OOS Parameter Store, Secrets Manager, DataHub,&amp;nbsp;&lt;/font&gt;&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;Log Service (SLS), Prometheus, Metrics Exporters, Grafana, Message Service (MNS), HBR Backup&lt;/span&gt;&lt;br&gt;&lt;ul style=&quot;margin-top: 0px; margin-bottom: 0px;&quot;&gt;&lt;li dir=&quot;ltr&quot; style=&quot;list-style-type: disc; background-color: transparent; vertical-align: baseline;&quot;&gt;&lt;p dir=&quot;ltr&quot; style=&quot;line-height: 1.38; margin-top: 0pt; margin-bottom: 0pt;&quot;&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;&lt;span style=&quot;background-color: transparent; vertical-align: baseline;&quot;&gt;&lt;b&gt;Security:&lt;/b&gt;&amp;nbsp;Cloud Security Center ( Anomaly Detection ),&lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&amp;nbsp;Anti-DDoS Pro ( DDOS Protection ), WAF ( Web Application Firewall),&amp;nbsp;&lt;/span&gt;&lt;/font&gt;&lt;/font&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;span style=&quot;&quot;&gt;&lt;/span&gt;&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;Cloud Security Center ( a comprehensive view of your security state ),&amp;nbsp;&lt;/span&gt;Cloud Firewall ( Central Firewall Management )&lt;br&gt;&lt;/font&gt;&lt;ul style=&quot;margin-top: 0px; margin-bottom: 0px;&quot;&gt;&lt;li dir=&quot;ltr&quot; style=&quot;list-style-type: disc; background-color: transparent; vertical-align: baseline;&quot;&gt;&lt;p dir=&quot;ltr&quot; style=&quot;line-height: 1.38; margin-top: 0pt; margin-bottom: 0pt;&quot;&gt;&lt;span style=&quot;background-color: transparent; vertical-align: baseline;&quot;&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;&lt;b&gt;Microservice Resources:&lt;/b&gt;&amp;nbsp; ACK Cluster ( separated per region)&lt;/font&gt;&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;ul style=&quot;margin-top: 0px; margin-bottom: 0px;&quot;&gt;&lt;li dir=&quot;ltr&quot; style=&quot;list-style-type: disc; background-color: transparent; vertical-align: baseline;&quot;&gt;&lt;p dir=&quot;ltr&quot; style=&quot;line-height: 1.38; margin-top: 0pt; margin-bottom: 0pt;&quot;&gt;&lt;b style=&quot;background-color: transparent;&quot;&gt;Cache:&lt;/b&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt; Alibaba Cloud CDN, Redis (Self-Managed)&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;ul style=&quot;margin-top: 0px; margin-bottom: 0px;&quot;&gt;&lt;li dir=&quot;ltr&quot; style=&quot;list-style-type: disc; background-color: transparent; vertical-align: baseline;&quot;&gt;&lt;p dir=&quot;ltr&quot; style=&quot;line-height: 1.38; margin-top: 0pt; margin-bottom: 0pt;&quot;&gt;&lt;span style=&quot;background-color: transparent; vertical-align: baseline;&quot;&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;&lt;b&gt;Database:&lt;/b&gt; PostgreSQL (Self-Managed), MongoDB (Self-Managed with cross-region replication)&lt;/font&gt;&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;li dir=&quot;ltr&quot; style=&quot;list-style-type: disc; background-color: transparent; vertical-align: baseline;&quot;&gt;&lt;p dir=&quot;ltr&quot; style=&quot;line-height: 1.38; margin-top: 0pt; margin-bottom: 0pt;&quot;&gt;&lt;span style=&quot;background-color: transparent; vertical-align: baseline;&quot;&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;&lt;b&gt;Queue:&lt;/b&gt; Kafka (Self-Managed), RabbitMQ (Self-Managed)&lt;/font&gt;&lt;/span&gt;&lt;/p&gt;&lt;/li&gt;&lt;/ul&gt;&lt;br style=&quot;&quot;&gt;&lt;/span&gt;" style="text;html=1;resizable=0;autosize=1;align=left;verticalAlign=middle;points=[];fillColor=none;strokeColor=none;rounded=0;fontSize=13;labelPosition=center;verticalLabelPosition=middle;" parent="1" vertex="1">
